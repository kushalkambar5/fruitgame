---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Contact Us | Fruit Gamer - The Ultimate Developer Merge Game" 
  description="Got questions, bugs, or feedback about the fruit merge game? Reach out to the Fruit Gamer team directly."
>
  <Navbar />

  <main class="w-full bg-canvas py-16 md:py-24 transition-colors duration-200">
    <div class="max-w-[800px] mx-auto px-4 md:px-6">
      
      <!-- Header -->
      <div class="mb-10 text-left border-b border-hairline pb-8">
        <span class="font-mono text-xs uppercase text-mute tracking-wider font-semibold">POST /api/v1/contact</span>
        <h1 class="font-sans font-semibold text-3xl md:text-4xl tracking-tight text-ink mt-2 mb-4">
          Contact the Team
        </h1>
        <p class="text-body text-sm max-w-xl leading-relaxed">
          Found a bug? Have a suggestion? Drop us a message, and our pipeline will route it to the right department.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        
        <!-- Contact Form Card -->
        <div class="border border-hairline bg-canvas p-6 rounded-xl shadow-sm">
          <form id="contact-form" class="flex flex-col gap-4">
            <div>
              <label for="name" class="block font-mono text-[11px] text-mute uppercase font-semibold mb-1.5">Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                class="w-full px-3 py-2 text-sm rounded bg-canvas border border-hairline focus:border-hairline-strong text-ink focus:outline-none transition-colors"
                placeholder="Developer"
              />
            </div>

            <div>
              <label for="email" class="block font-mono text-[11px] text-mute uppercase font-semibold mb-1.5">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                class="w-full px-3 py-2 text-sm rounded bg-canvas border border-hairline focus:border-hairline-strong text-ink focus:outline-none transition-colors"
                placeholder="dev@fruitgamer.com"
              />
            </div>

            <div>
              <label for="subject" class="block font-mono text-[11px] text-mute uppercase font-semibold mb-1.5">Category</label>
              <select 
                id="subject" 
                name="subject" 
                required 
                class="w-full px-3 py-2 text-sm rounded bg-canvas border border-hairline focus:border-hairline-strong text-ink focus:outline-none transition-colors"
              >
                <option value="general">General Feedback</option>
                <option value="bug">Report a Bug (Matter.js)</option>
                <option value="feature">Request Feature / Mode</option>
                <option value="business">Business Inquiries</option>
              </select>
            </div>

            <div>
              <label for="message" class="block font-mono text-[11px] text-mute uppercase font-semibold mb-1.5">Inquiry Details</label>
              <textarea 
                id="message" 
                name="message" 
                rows="4" 
                required 
                class="w-full px-3 py-2 text-sm rounded bg-canvas border border-hairline focus:border-hairline-strong text-ink focus:outline-none transition-colors"
                placeholder="Describe your issue or suggestions here..."
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="h-10 mt-2 px-6 bg-ink text-canvas hover:bg-body font-medium text-sm rounded-md transition-colors duration-150 cursor-pointer w-full text-center flex items-center justify-center gap-2"
            >
              <span>Send Message</span>
            </button>
          </form>
        </div>

        <!-- Terminal Log / Context Column -->
        <div class="flex flex-col gap-4">
          <!-- Quick stats -->
          <div class="border border-hairline bg-canvas p-4 rounded-lg shadow-sm">
            <h4 class="font-mono text-[11px] uppercase tracking-wider text-mute font-semibold mb-2">Service Status</h4>
            <div class="flex items-center gap-2">
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-success"></span>
              </span>
              <span class="font-mono text-xs text-ink">API Gateway: Online (200 OK)</span>
            </div>
            <p class="text-xs text-mute mt-2">
              Our support gateway is listening for incoming logs. Typical response time is under 12 hours.
            </p>
          </div>

          <!-- Dynamic Console Terminal -->
          <div class="border border-hairline-strong bg-black text-gray-300 p-4 rounded-lg shadow-md font-mono text-xs min-h-[180px] flex flex-col justify-between">
            <div>
              <div class="flex items-center justify-between border-b border-zinc-800 pb-2 mb-2">
                <span class="text-zinc-500 text-[10px]">INQUIRY PIPELINE LOG</span>
                <span class="w-2.5 h-2.5 rounded-full bg-zinc-800"></span>
              </div>
              <div id="terminal-content" class="space-y-1.5 text-green-400">
                <div class="text-zinc-500">// Terminal ready...</div>
                <div class="text-zinc-500">awaiting payload deployment...</div>
              </div>
            </div>
            
            <div class="text-zinc-600 text-[10px] mt-4 pt-2 border-t border-zinc-900">
              Session ID: {Math.random().toString(36).substring(2, 9).toUpperCase()}
            </div>
          </div>
        </div>

      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  const terminalContent = document.getElementById('terminal-content') as HTMLDivElement;

  if (contactForm && terminalContent) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(contactForm);
      const name = formData.get('name') as string;
      const email = formData.get('email') as string;
      const category = formData.get('subject') as string;

      // Clear terminal and start fake build logging
      terminalContent.innerHTML = '';
      
      const logs = [
        { text: `[POST] Initializing contact request pipeline...`, color: 'text-blue-400' },
        { text: `[PARAM] validation complete: name="${name}"`, color: 'text-zinc-500' },
        { text: `[CONNECT] Resolving gateway address...`, color: 'text-zinc-500' },
        { text: `[PAYLOAD] Serializing form content structure...`, color: 'text-zinc-500' },
        { text: `[SEND] Shipping payload package (size ~1.2kb)...`, color: 'text-yellow-500' },
        { text: `[SERVER] Connection established with mail server...`, color: 'text-zinc-500' },
        { text: `[SERVER] Inquiry queued under id: INQ-${Math.floor(Math.random() * 90000 + 10000)}`, color: 'text-zinc-500' },
        { text: `[SUCCESS] 200 OK: message successfully shipped!`, color: 'text-green-400 font-bold' }
      ];

      let delay = 0;
      logs.forEach((log, index) => {
        setTimeout(() => {
          const div = document.createElement('div');
          div.className = log.color;
          div.textContent = log.text;
          terminalContent.appendChild(div);
          
          // Scroll terminal down
          terminalContent.scrollTop = terminalContent.scrollHeight;
        }, delay);
        delay += 350;
      });

      // Clear input fields after success simulation
      setTimeout(() => {
        contactForm.reset();
      }, delay);
    });
  }
</script>
