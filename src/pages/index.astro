---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FruitGame from '../components/FruitGame.astro';
import { FRUITS } from '../components/game';
import FAQ from '../components/FAQ.astro';
---

<Layout>
  <!-- Global navigation -->
  <Navbar />

  <!-- Hero Section with Atmospheric Mesh Gradient Backdrop -->
  <section class="relative w-full overflow-hidden bg-canvas transition-colors duration-200 py-20 lg:py-32">
    <!-- Mesh Gradients absolute positioned and heavily blurred -->
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none opacity-40 dark:opacity-20">
      <div class="absolute top-[-10%] left-[20%] w-[350px] h-[350px] rounded-full bg-develop-start filter blur-[100px] animate-pulse" style="animation-duration: 12s;"></div>
      <div class="absolute top-[10%] right-[20%] w-[400px] h-[400px] rounded-full bg-preview-start filter blur-[120px] animate-pulse" style="animation-duration: 8s; animation-delay: 2s;"></div>
      <div class="absolute bottom-[-10%] left-[35%] w-[380px] h-[380px] rounded-full bg-ship-start filter blur-[110px] animate-pulse" style="animation-duration: 15s; animation-delay: 4s;"></div>
    </div>

    <div class="relative z-10 max-w-[1400px] mx-auto px-4 md:px-6 flex flex-col items-center text-center">

      <!-- Sentence case period terminated headline -->
      <h1 class="font-sans font-semibold text-4xl sm:text-5xl md:text-6xl tracking-tight text-ink mb-6 max-w-4xl leading-[1.05]">
        Drop, Match, and Grow Huge Fruits!
      </h1>

      <!-- Body lead paragraph -->
      <p class="font-sans text-body text-base sm:text-lg md:text-xl max-w-2xl mb-8 leading-relaxed">
        Meet Fruit Gamer: a super fun game where you drop and combine fruits! Can you merge your way up to the giant watermelon?
      </p>

      <!-- CTA buttons -->
      <div class="flex items-center gap-3">
        <a 
          href="#game" 
          class="h-11 px-6 bg-ink text-canvas hover:bg-body font-medium text-sm rounded-full transition-colors duration-150 shadow-sm flex items-center"
        >
          Play Now
        </a>
        <a 
          href="#how-to-play" 
          class="h-11 px-6 bg-canvas text-ink hover:bg-canvas-soft-2 border border-hairline font-medium text-sm rounded-full transition-colors duration-150 shadow-sm flex items-center"
        >
          How to Play
        </a>
      </div>
    </div>
  </section>

  <!-- Interactive Game Area -->
  <section id="game" class="w-full bg-canvas-soft border-y border-hairline transition-colors duration-200 py-12">
    <FruitGame />
  </section>

  <!-- Progression System Path -->
  <section id="progression" class="w-full bg-canvas transition-colors duration-200 py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <span class="font-mono text-xs uppercase text-mute tracking-wider font-semibold">Fruit Evolution</span>
        <h2 class="font-sans font-semibold text-2xl md:text-3xl tracking-tight text-ink mt-2 mb-4">
          Watch your fruits grow!
        </h2>
        <p class="text-body text-sm max-w-lg mx-auto">
          Drop two of the same fruits together to combine them into a bigger, better fruit. Keep going to reach the top!
        </p>
      </div>

      <!-- Release path scrollable flex -->
      <div class="w-full overflow-x-auto pb-4 scrollbar-thin">
        <div class="min-w-[900px] flex items-center justify-between px-4">
          {FRUITS.map((fruit, idx) => (
            <div class="flex flex-col items-center gap-3 relative flex-1 group">
              <!-- Connection Line between items -->
              {idx < FRUITS.length - 1 && (
                <div class="absolute top-10 left-[50%] right-[-50%] h-[1px] bg-hairline group-hover:bg-hairline-strong transition-colors duration-200 z-0"></div>
              )}
              
              <!-- Badge -->
              <div 
                class="w-20 h-20 rounded-full flex flex-col items-center justify-center border border-hairline bg-canvas-soft-2 hover:bg-canvas shadow-sm transition-all duration-200 z-10 scale-100 group-hover:scale-110 relative"
                style={`box-shadow: 0 0 10px rgba(0,0,0,0.02);`}
              >
                <!-- Color glowing backplate -->
                <div 
                  class="absolute inset-0 rounded-full opacity-5 group-hover:opacity-15 transition-opacity" 
                  style={`background-color: ${fruit.color};`}
                ></div>
                <span class="text-3xl select-none">{fruit.emoji}</span>
              </div>
              
              <!-- Labels -->
              <div class="flex flex-col items-center text-center z-10">
                <span class="font-mono text-[11px] font-semibold text-ink">{fruit.name}</span>
                <span class="font-mono text-[10px] text-mute uppercase mt-0.5">Level {idx + 1}</span>
                <span class="text-[10px] px-1.5 py-0.5 rounded bg-canvas-soft-2 border border-hairline mt-1.5 text-mute font-mono">
                  +{fruit.score}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Environment / Modes Cards (3-up) -->
  <section id="modes" class="w-full bg-canvas-soft border-t border-hairline transition-colors duration-200 py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <span class="font-mono text-xs uppercase text-mute tracking-wider font-semibold">Game Modes</span>
        <h2 class="font-sans font-semibold text-2xl md:text-3xl tracking-tight text-ink mt-2 mb-4">
          Ways to Play!
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1: Classic (Light canvas style) -->
        <div class="flex flex-col justify-between p-6 bg-canvas text-ink rounded-lg shadow-sm border border-hairline min-h-[220px] relative overflow-hidden group hover:shadow-md transition-shadow">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-[10px] uppercase tracking-wider text-mute font-semibold">Mode #01</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-canvas-soft-2 border border-hairline font-mono text-success">Normal</span>
            </div>
            <h3 class="font-sans font-semibold text-xl tracking-tight text-ink mb-2">Classic Game</h3>
            <p class="text-[13px] text-body leading-relaxed">
              Drop fruits carefully! Don't let the pile cross the red line at the top, or it's game over!
            </p>
          </div>
          <a href="#game" class="mt-6 text-xs font-mono text-link hover:underline flex items-center gap-1">
            Play Classic &rarr;
          </a>
        </div>

        <!-- Card 2: Zen (Light canvas style) -->
        <div class="flex flex-col justify-between p-6 bg-canvas text-ink rounded-lg shadow-sm border border-hairline min-h-[220px] relative overflow-hidden group hover:shadow-md transition-shadow">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-[10px] uppercase tracking-wider text-mute font-semibold">Mode #02</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-canvas-soft-2 border border-hairline font-mono text-body">Chill</span>
            </div>
            <h3 class="font-sans font-semibold text-xl tracking-tight text-ink mb-2">Zen Mode</h3>
            <p class="text-[13px] text-body leading-relaxed">
              Just relax and merge fruits. No losing, no stress! Keep playing as long as you want.
            </p>
          </div>
          <a href="#game" class="mt-6 text-xs font-mono text-link hover:underline flex items-center gap-1">
            Play Zen Mode &rarr;
          </a>
        </div>

        <!-- Card 3: Time Attack (Light canvas style) -->
        <div class="flex flex-col justify-between p-6 bg-canvas text-ink rounded-lg shadow-sm border border-hairline min-h-[220px] relative overflow-hidden group hover:shadow-md transition-shadow">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-[10px] uppercase tracking-wider text-mute font-semibold">Mode #03</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-canvas-soft-2 border border-hairline font-mono text-warning-deep">Fast</span>
            </div>
            <h3 class="font-sans font-semibold text-xl tracking-tight text-ink mb-2">Time Sprint</h3>
            <p class="text-[13px] text-body leading-relaxed">
              Go super fast! Get as many points and merges as you can in just 120 seconds.
            </p>
          </div>
          <a href="#game" class="mt-6 text-xs font-mono text-link hover:underline flex items-center gap-1">
            Start Sprint &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Play & Instructions (Readme format) -->
  <section id="how-to-play" class="w-full bg-canvas transition-colors duration-200 py-16 md:py-24">
    <div class="max-w-[800px] mx-auto px-4 md:px-6">
      
      <!-- Styled README structure -->
      <div class="border border-hairline rounded-lg overflow-hidden shadow-sm">
        <!-- Tab editor header -->
        <div class="bg-canvas-soft-2 border-b border-hairline px-4 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-hairline-strong flex items-center justify-center text-[8px] font-mono select-none">?</span>
            <span class="font-mono text-xs font-semibold text-body">Instructions</span>
          </div>
          <span class="font-mono text-[10px] text-mute">HOW TO PLAY</span>
        </div>
        
        <div class="p-6 md:p-8 bg-canvas text-ink select-text font-sans leading-relaxed text-sm md:text-base prose dark:prose-invert max-w-none">
          <h1 class="text-2xl font-bold tracking-tight text-ink mb-4 pb-2 border-b border-hairline flex items-center gap-2">
            <span class="text-develop-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="6" y1="12" x2="10" y2="12"></line>
                <line x1="8" y1="10" x2="8" y2="14"></line>
                <line x1="15" y1="13" x2="15.01" y2="13"></line>
                <line x1="18" y1="11" x2="18.01" y2="11"></line>
                <rect x="2" y="6" width="20" height="12" rx="3"></rect>
              </svg>
            </span>
            How to Play Fruit Gamer
          </h1>
          
          <p class="text-body mb-6">
            Fruit Gamer is a fun puzzle game where you drop fruits into a box. Combine the same fruits to make bigger ones and score points!
          </p>

          <h2 class="text-lg font-semibold tracking-tight text-ink mt-6 mb-3 flex items-center gap-2">
            <span class="text-preview-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
              </svg>
            </span>
            Game Rules
          </h2>
          
          <h3 class="text-sm font-semibold font-mono text-ink mt-4 mb-2">1. Drop Fruits</h3>
          <p class="text-body mb-4">
            Move your mouse or finger left and right to aim. <strong>Click or tap</strong> to drop the fruit into the box!
          </p>

          <h3 class="text-sm font-semibold font-mono text-ink mt-4 mb-2">2. Combine & Grow!</h3>
          <p class="text-body mb-4">
            When two of the same fruits touch (like Cherry + Cherry), they magically combine into a bigger fruit and give you points!
          </p>

          <h3 class="text-sm font-semibold font-mono text-ink mt-4 mb-2">3. Fun Power-Ups</h3>
          <p class="text-body mb-4">
            If you get stuck, use these cool power-up buttons:
          </p>
          <ul class="list-disc pl-5 mb-4 flex flex-col gap-1.5 text-body text-xs font-mono">
            <li><strong class="text-ink">Shake</strong>: Jiggles the box to mix up the fruits.</li>
            <li><strong class="text-ink">Clear Cherries</strong>: Removes all the tiny cherries to give you more room.</li>
            <li><strong class="text-ink">Magic Upgrade</strong>: Magically upgrades a fruit to the next size!</li>
          </ul>

          <h3 class="text-sm font-semibold font-mono text-ink mt-4 mb-2">4. Don't Overflow!</h3>
          <p class="text-body mb-4">
            Be careful! If your fruits pile up too high and cross the red line at the top, the game is over! Keep merging to make room.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About & SEO Deep Dive Section -->
  <section id="about-game" class="w-full bg-canvas-soft border-t border-hairline transition-colors duration-200 py-16 md:py-24">
    <div class="max-w-[1000px] mx-auto px-4 md:px-6">
      
      <!-- Styled container -->
      <div class="border border-hairline rounded-lg bg-canvas overflow-hidden shadow-sm">
        
        <!-- Header -->
        <div class="bg-canvas-soft-2 border-b border-hairline px-4 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2 font-mono text-xs text-mute">
            <span class="w-2.5 h-2.5 rounded-full bg-develop-start inline-block"></span>
            <span>docs / fruit-gamer-overview.md</span>
          </div>
          <span class="font-mono text-[10px] text-mute">SEO DOCUMENTATION</span>
        </div>

        <!-- Content Area -->
        <div class="p-6 md:p-10 select-text font-sans leading-relaxed text-sm md:text-base text-body">
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-ink mb-6 flex items-center gap-2">
            Fruit Gamer: The Ultimate Guide to the Best Fruit Merge Game Online
          </h2>
          
          <p class="mb-6 leading-relaxed">
            Welcome to <strong>Fruit Gamer</strong>, the web's premium home for physics-based puzzle entertainment. If you are looking for an addictive, engaging, and completely <strong>free fruit merge game</strong>, you have come to the right place. Our unique version combines the classic mechanics of the viral Japanese Suika Game with a modern developer-styled dashboard UI, offering a fresh aesthetic and smooth web performance. Play the <strong>fruit merge game online</strong> directly in your browser with no downloads, setup, or hassle.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-8 pt-8 border-t border-hairline">
            <div>
              <h3 class="text-lg font-semibold tracking-tight text-ink mb-3 flex items-center gap-2">
                <span class="text-develop-start">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                  </svg>
                </span>
                What is the Fruit Gamer Merge Game?
              </h3>
              <p class="mb-4 text-xs sm:text-sm leading-relaxed">
                At its core, Fruit Gamer is a physics-based <strong>fruit merge game free</strong> to play for gamers of all ages. Inspired by popular matching and stack puzzles, your goal is simple: drop colorful fruits into a box and merge identical items to evolve them. Starting with tiny cherries, you will combine matching items to unlock strawberries, grapes, oranges, and apples, eventually climbing all the way to the giant melon. The ultimate objective is to create the largest possible fruit: the legendary watermelon in this <strong>watermelon fruit merge game</strong>.
              </p>
              <p class="text-xs sm:text-sm leading-relaxed">
                To play, simply move your mouse or tap your screen to position the active fruit preview, then click to drop. Gravity and Matter.js physics take over from there. When two fruits of the exact same type collide, they combine and release score points, clearing space inside the container. But watch out! If your pile grows too high and crosses the red boundary line for more than two seconds, your pipeline crashes and it is game over.
              </p>
            </div>
            
            <div>
              <h3 class="text-lg font-semibold tracking-tight text-ink mb-3 flex items-center gap-2">
                <span class="text-ship-end">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                  </svg>
                </span>
                Why is This the Best Fruit Merge Game?
              </h3>
              <p class="mb-4 text-xs sm:text-sm leading-relaxed">
                With dozens of clones on the app stores, what makes Fruit Gamer the <strong>best fruit merge game</strong> on the web? First, we prioritize user experience. This is a <strong>fruit merge game no ads</strong> disruptor, meaning you can play without annoying pop-ups or video interruptions interrupting your high-score runs.
              </p>
              <p class="mb-4 text-xs sm:text-sm leading-relaxed">
                Second, it is a fully responsive <strong>free online fruit merge game</strong> optimized for both desktop and mobile devices. Whether you are on a Chromebook at school or a phone on the go, our <strong>fruit merge game online free</strong> version loads instantly and runs at a smooth 60 frames per second.
              </p>
              <p class="text-xs sm:text-sm leading-relaxed">
                Third, if you are playing from a restricted network, you will be happy to know that this is a <strong>fruit merge game unblocked</strong> platform, allowing you to access clean puzzle fun anytime, anywhere. Furthermore, unlike the console version of the <strong>fruit merge game switch</strong> players enjoy, our web edition features custom developer-dashboard aesthetics.
              </p>
            </div>
          </div>

          <div class="my-8 pt-8 border-t border-hairline">
            <h3 class="text-lg font-semibold tracking-tight text-ink mb-4 flex items-center gap-2">
              <span class="text-success">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                  <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
              </span>
              Understanding the Fruit Evolution Pathway
            </h3>
            <p class="mb-4 text-xs sm:text-sm">
              To succeed in this <strong>fruit merge game original</strong>, it helps to understand the progression. Let's look at the upgrade tree. What is the official <strong>fruit merge game name</strong> for each evolution step? Here is the complete list of fruits and their scoring values:
            </p>
            <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 font-mono text-xs">
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center">
                <span class="text-xl block mb-1">🍒</span>
                <span class="font-bold text-ink">Cherry</span>
                <span class="text-mute block text-[10px] mt-0.5">Lvl 1 • +1 pt</span>
              </div>
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center">
                <span class="text-xl block mb-1">🍓</span>
                <span class="font-bold text-ink">Strawberry</span>
                <span class="text-mute block text-[10px] mt-0.5">Lvl 2 • +2 pts</span>
              </div>
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center">
                <span class="text-xl block mb-1">🍇</span>
                <span class="font-bold text-ink">Grape</span>
                <span class="text-mute block text-[10px] mt-0.5">Lvl 3 • +4 pts</span>
              </div>
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center">
                <span class="text-xl block mb-1">🍊</span>
                <span class="font-bold text-ink">Orange</span>
                <span class="text-mute block text-[10px] mt-0.5">Lvl 4 • +8 pts</span>
              </div>
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center">
                <span class="text-xl block mb-1">🍎</span>
                <span class="font-bold text-ink">Apple</span>
                <span class="text-mute block text-[10px] mt-0.5">Lvl 5 • +16 pts</span>
              </div>
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center">
                <span class="text-xl block mb-1">🍐</span>
                <span class="font-bold text-ink">Pear</span>
                <span class="text-mute block text-[10px] mt-0.5">Lvl 6 • +32 pts</span>
              </div>
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center">
                <span class="text-xl block mb-1">🍑</span>
                <span class="font-bold text-ink">Peach</span>
                <span class="text-mute block text-[10px] mt-0.5">Lvl 7 • +64 pts</span>
              </div>
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center">
                <span class="text-xl block mb-1">🍍</span>
                <span class="font-bold text-ink">Pineapple</span>
                <span class="text-mute block text-[10px] mt-0.5">Lvl 8 • +128 pts</span>
              </div>
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center">
                <span class="text-xl block mb-1">🍈</span>
                <span class="font-bold text-ink">Melon</span>
                <span class="text-mute block text-[10px] mt-0.5">Lvl 9 • +256 pts</span>
              </div>
              <div class="p-2.5 rounded bg-canvas-soft border border-hairline text-center border-develop-start bg-develop-start/5">
                <span class="text-xl block mb-1">🍉</span>
                <span class="font-bold text-ink">Watermelon</span>
                <span class="text-develop-start block text-[10px] mt-0.5 font-bold">Lvl 10 • +512 pts</span>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-8 pt-8 border-t border-hairline">
            <div>
              <h3 class="text-lg font-semibold tracking-tight text-ink mb-3 flex items-center gap-2">
                <span class="text-warning">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .5 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"></path>
                    <line x1="9" y1="18" x2="15" y2="18"></line>
                    <line x1="10" y1="22" x2="14" y2="22"></line>
                  </svg>
                </span>
                Tips and Strategies for High Scores
              </h3>
              <ul class="list-disc pl-5 text-xs sm:text-sm leading-relaxed flex flex-col gap-2">
                <li><strong>Aim carefully</strong>: Think about where the fruit will bounce and roll. Because of realistic circle physics, round fruits will roll off each other's curves.</li>
                <li><strong>Manage your space</strong>: Keep your largest fruits at the bottom and smaller ones on top. If a small cherry gets trapped underneath a massive pineapple, it can block further merges.</li>
                <li><strong>Use your power-ups</strong>: Take advantage of custom commands! Run the `shake` box charge to mix up stuck fruits, trigger the garbage collector (`gc`) to purge tiny cherries when the container is full, or apply a `hotfix` to upgrade a fruit in place.</li>
              </ul>
            </div>
            <div>
              <h3 class="text-lg font-semibold tracking-tight text-ink mb-3 flex items-center gap-2">
                <span class="text-ship-end">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
                    <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
