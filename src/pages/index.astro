---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FruitGame from '../components/FruitGame.astro';
import { FRUITS } from '../components/game';
import FAQ from '../components/FAQ.astro';
---

<Layout>
  <!-- Global navigation -->
  <Navbar />

  <!-- Hero Section with Atmospheric Cloud Backdrop -->
  <section class="relative w-full overflow-hidden bg-[#e0f2fe] dark:bg-canvas-soft-2 transition-colors duration-200 py-16 lg:py-24 border-b-3 border-[#2c1e13]">
    <!-- Mesh Gradients absolute positioned and heavily blurred -->
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none opacity-40 dark:opacity-10">
      <div class="absolute top-[10%] left-[10%] animate-pulse flex items-center" style="animation-duration: 6s;">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-[#2c1e13]/10 dark:text-ink/5 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="2">
          <path d="M17.5 19A3.5 3.5 0 0 0 21 15.5c0-2.79-2.54-4.5-5-4.5-.47 0-.89.09-1.25.27A5 5 0 0 0 5 13c0 2.2 1.8 4 4 4h8.5Z"></path>
        </svg>
      </div>
      <div class="absolute top-[35%] right-[12%] animate-pulse flex items-center" style="animation-duration: 9s; animation-delay: 1.5s;">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-[#2c1e13]/10 dark:text-ink/5 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="2">
          <path d="M17.5 19A3.5 3.5 0 0 0 21 15.5c0-2.79-2.54-4.5-5-4.5-.47 0-.89.09-1.25.27A5 5 0 0 0 5 13c0 2.2 1.8 4 4 4h8.5Z"></path>
        </svg>
      </div>
      <div class="absolute bottom-[8%] left-[45%] animate-pulse flex items-center" style="animation-duration: 7s; animation-delay: 3s;">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[#2c1e13]/10 dark:text-ink/5 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="2">
          <path d="M17.5 19A3.5 3.5 0 0 0 21 15.5c0-2.79-2.54-4.5-5-4.5-.47 0-.89.09-1.25.27A5 5 0 0 0 5 13c0 2.2 1.8 4 4 4h8.5Z"></path>
        </svg>
      </div>
    </div>

    <div class="relative z-10 max-w-[1200px] mx-auto px-4 md:px-6 flex flex-col items-center text-center">
      <!-- Playful sentence headline -->
      <h1 class="font-black text-4xl sm:text-5xl md:text-6xl text-[#2c1e13] dark:text-ink mb-6 max-w-4xl leading-tight">
        Drop, Match, and Grow Giant Fruits!
      </h1>

      <!-- Body lead paragraph -->
      <p class="font-bold text-stone-600 dark:text-body text-base sm:text-lg md:text-xl max-w-2xl mb-8 leading-relaxed">
        Welcome to Fruit Joy! A super fun puzzle adventure where you match cute cartoon fruits to make them grow. Can you merge your way to the giant Watermelon?
      </p>

      <!-- CTA buttons -->
      <div class="flex items-center gap-4">
        <a 
          href="#game" 
          class="h-12 px-8 bg-[#fbbf24] hover:bg-[#f59e0b] text-[#3b2314] border-3 border-[#2c1e13] font-black text-base rounded-full transition-all duration-150 shadow-md active:scale-95 flex items-center"
        >
          Play Now!
        </a>
        <a 
          href="#how-to-play" 
          class="h-12 px-8 bg-white hover:bg-stone-50 dark:bg-canvas-soft-2 dark:hover:bg-canvas text-[#2c1e13] dark:text-ink border-3 border-[#2c1e13] dark:border-ink font-black text-base rounded-full transition-all duration-150 shadow-md active:scale-95 flex items-center"
        >
          Rules
        </a>
      </div>
    </div>
  </section>

  <!-- Interactive Game Area -->
  <section id="game" class="w-full bg-[#fefbe8] dark:bg-canvas-soft border-b-3 border-[#2c1e13] py-12 transition-colors duration-200">
    <FruitGame />
  </section>

  <!-- Progression System Path -->
  <section id="progression" class="w-full bg-white dark:bg-canvas-soft border-b-3 border-[#2c1e13] py-16 transition-colors duration-200">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <span class="bg-amber-100 text-amber-800 border-2 border-[#2c1e13] text-xs font-black px-3 py-1 rounded-full uppercase tracking-wider">Evolution Tree</span>
        <h2 class="font-black text-3xl text-[#2c1e13] dark:text-ink mt-4 mb-2">
          Watch Your Fruits Grow!
        </h2>
        <p class="text-stone-500 dark:text-body font-bold text-sm max-w-lg mx-auto">
          Combine two identical fruits to level them up into a bigger, happier fruit. Evolve them all the way from a cherry to a watermelon!
        </p>
      </div>

      <!-- Release path scrollable flex (Wooden plank design) -->
      <div class="w-full overflow-x-auto pb-6 scrollbar-thin">
        <div class="min-w-[1000px] bg-[#b45309] border-4 border-[#2c1e13] rounded-3xl p-6 flex items-center justify-between px-6 shadow-xl gap-4">
          {FRUITS.map((fruit, idx) => (
            <div class="flex flex-col items-center gap-3 relative flex-1 group">
              <!-- Connection Line between items -->
              {idx < FRUITS.length - 1 && (
                <div class="absolute top-10 left-[50%] right-[-50%] h-1 bg-[#2c1e13] z-0"></div>
              )}
              
              <!-- Badge -->
              <div 
                class="w-20 h-20 rounded-full flex flex-col items-center justify-center border-3 border-[#2c1e13] bg-[#fffbeb] hover:bg-orange-50 shadow-md transition-all duration-150 z-10 scale-100 group-hover:scale-110 relative"
              >
                <!-- Color glowing backplate -->
                <div 
                  class="absolute inset-0 rounded-full opacity-10 group-hover:opacity-20 transition-opacity" 
                  style={`background-color: ${fruit.color};`}
                ></div>
                <span class="text-4xl select-none">{fruit.emoji}</span>
              </div>
              
              <!-- Labels -->
              <div class="flex flex-col items-center text-center z-10 font-black">
                <span class="text-xs text-[#fffbeb]">{fruit.name}</span>
                <span class="text-[9px] text-amber-200 uppercase mt-0.5">Level {idx + 1}</span>
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-[#fffbeb] text-[#2c1e13] border-2 border-[#2c1e13] mt-1 shadow-sm font-black">
                  +{fruit.score} pts
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Environment / Modes Cards (3-up) -->
  <section id="modes" class="w-full bg-[#f8fafc] dark:bg-canvas-soft border-b-3 border-[#2c1e13] transition-colors duration-200 py-16">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <span class="bg-rose-100 text-rose-800 border-2 border-[#2c1e13] text-xs font-black px-3 py-1 rounded-full uppercase tracking-wider">How to Play</span>
        <h2 class="font-black text-3xl text-[#2c1e13] dark:text-ink mt-4 mb-2">
          Choose Your Adventure!
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1: Classic -->
        <div class="flex flex-col justify-between p-6 bg-white dark:bg-canvas rounded-3xl shadow-lg border-3 border-[#2c1e13] min-h-[220px] transition-transform duration-150 hover:-translate-y-1">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs font-black text-amber-600 uppercase">Classic</span>
              <span class="text-xs px-2.5 py-0.5 rounded-full bg-green-100 text-green-800 border-2 border-[#2c1e13] font-black">Normal</span>
            </div>
            <h3 class="font-black text-xl text-[#2c1e13] dark:text-ink mb-2">Classic Game</h3>
            <p class="text-sm font-bold text-stone-500 dark:text-body leading-relaxed">
              Drop fruits carefully! Don't let the pile cross the warning line at the top, or it's game over!
            </p>
          </div>
          <a href="#game" class="mt-6 text-xs font-black text-blue-600 dark:text-link hover:underline flex items-center gap-1">
            Let's Play &rarr;
          </a>
        </div>

        <!-- Card 2: Zen -->
        <div class="flex flex-col justify-between p-6 bg-white dark:bg-canvas rounded-3xl shadow-lg border-3 border-[#2c1e13] min-h-[220px] transition-transform duration-150 hover:-translate-y-1">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs font-black text-amber-600 uppercase">Zen</span>
              <span class="text-xs px-2.5 py-0.5 rounded-full bg-blue-100 text-blue-800 border-2 border-[#2c1e13] font-black">Chill</span>
            </div>
            <h3 class="font-black text-xl text-[#2c1e13] dark:text-ink mb-2">Zen Mode</h3>
            <p class="text-sm font-bold text-stone-500 dark:text-body leading-relaxed">
              Just relax and merge fruits. No losing, no stress! Keep playing as long as you want.
            </p>
          </div>
          <a href="#game" class="mt-6 text-xs font-black text-blue-600 dark:text-link hover:underline flex items-center gap-1">
            Start Zen Mode &rarr;
          </a>
        </div>

        <!-- Card 3: Time Attack -->
        <div class="flex flex-col justify-between p-6 bg-white dark:bg-canvas rounded-3xl shadow-lg border-3 border-[#2c1e13] min-h-[220px] transition-transform duration-150 hover:-translate-y-1">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs font-black text-amber-600 uppercase">Sprint</span>
              <span class="text-xs px-2.5 py-0.5 rounded-full bg-rose-100 text-rose-800 border-2 border-[#2c1e13] font-black">Fast</span>
            </div>
            <h3 class="font-black text-xl text-[#2c1e13] dark:text-ink mb-2">Time Sprint</h3>
            <p class="text-sm font-bold text-stone-500 dark:text-body leading-relaxed">
              Go super fast! Get as many points and merges as you can in just 120 seconds.
            </p>
          </div>
          <a href="#game" class="mt-6 text-xs font-black text-blue-600 dark:text-link hover:underline flex items-center gap-1">
            Start Sprint &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Play & Instructions -->
  <section id="how-to-play" class="w-full bg-white dark:bg-canvas-soft border-b-3 border-[#2c1e13] transition-colors duration-200 py-16">
    <div class="max-w-[800px] mx-auto px-4 md:px-6">
      
      <!-- Styled Corkboard/Paper structure -->
      <div class="border-4 border-[#2c1e13] rounded-3xl overflow-hidden shadow-xl bg-amber-50 dark:bg-canvas">
        <!-- Cute header -->
        <div class="bg-amber-100 dark:bg-canvas-soft-2 border-b-3 border-[#2c1e13] px-6 py-4 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-800 dark:text-ink fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path>
              <path d="M6 6h10"></path>
              <path d="M6 10h10"></path>
            </svg>
            <span class="font-black text-base text-[#2c1e13] dark:text-ink">Game Rules & Tips</span>
          </div>
        </div>
        
        <div class="p-6 md:p-8 text-[#2c1e13] dark:text-body leading-relaxed text-sm md:text-base font-bold">
          <h2 class="text-2xl font-black mb-4 pb-2 border-b-2 border-[#2c1e13]/10 dark:border-hairline flex items-center gap-2">
            How to Play Fruit Joy
          </h2>
          
          <p class="text-stone-600 dark:text-body mb-6 font-bold">
            Fruit Joy is a physics puzzle game where you drop fruits. When two of the same fruits touch, they combine into a bigger size and give you lots of points!
          </p>

          <h3 class="text-lg font-black text-amber-800 dark:text-ink mb-3 flex items-center gap-2">
            Rules of the Game
          </h3>
          
          <h4 class="text-sm font-black text-[#2c1e13] dark:text-ink mt-4 mb-1">1. Aim & Drop</h4>
          <p class="text-stone-600 dark:text-body mb-4 font-medium">
            Move your finger or mouse left and right to aim. <strong>Click or tap</strong> to drop the fruit into the container!
          </p>

          <h4 class="text-sm font-black text-[#2c1e13] dark:text-ink mt-4 mb-1">2. Match to Evolve</h4>
          <p class="text-stone-600 dark:text-body mb-4 font-medium">
            Merge matching fruits (like Grape + Grape) to level them up into a larger fruit (like Orange)!
          </p>

          <h4 class="text-sm font-black text-[#2c1e13] dark:text-ink mt-4 mb-1">3. Don't Overflow!</h4>
          <p class="text-stone-600 dark:text-body mb-4 font-medium">
            Be careful! If fruits pile up too high and stay in the <strong>DANGER ZONE</strong> at the top for more than 2 seconds, the game is over!
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About & SEO Deep Dive Section -->
  <section id="about-game" class="w-full bg-[#f8fafc] dark:bg-canvas-soft transition-colors duration-200 py-16">
    <div class="max-w-[1000px] mx-auto px-4 md:px-6">
      
      <!-- Styled container -->
      <div class="border-4 border-[#2c1e13] rounded-3xl bg-white dark:bg-canvas overflow-hidden shadow-lg">
        
        <!-- Header -->
        <div class="bg-stone-100 dark:bg-canvas-soft-2 border-b-3 border-[#2c1e13] px-4 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2 font-black text-xs text-stone-600 dark:text-body">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path>
              <path d="M6 6h10"></path>
              <path d="M6 10h10"></path>
            </svg>
            <span>Fruit Joy Overview & SEO Guide</span>
          </div>
        </div>

        <!-- Content Area -->
        <div class="p-6 md:p-10 text-stone-600 dark:text-body leading-relaxed text-sm md:text-base font-medium">
          <h2 class="text-2xl sm:text-3xl font-black text-[#2c1e13] dark:text-ink mb-6 flex items-center gap-2">
            Fruit Joy: The Cutest Free Fruit Merge Game Online!
          </h2>
          
          <p class="mb-6 leading-relaxed font-bold">
            Welcome to <strong>Fruit Joy</strong>, a physics-based matching game designed for kids and fruit lovers of all ages! If you are searching for an addictive, cute, and <strong>free fruit merge game</strong>, Fruit Joy is here to bring a smile to your face. Play directly in your browser with zero downloads, no setup, and absolutely no ads disrupting your matching fun!
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-8 pt-8 border-t-2 border-[#2c1e13]/10">
            <div>
              <h3 class="text-lg font-black text-[#2c1e13] dark:text-ink mb-3 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-[#fbbf24] fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
                What is Fruit Joy?
              </h3>
              <p class="mb-4 text-xs sm:text-sm leading-relaxed">
                Fruit Joy is a matching game where you drop colorful fruits into a box. Evolve small fruits into bigger ones: start with cherries, combine them into strawberries, grapes, oranges, apples, and work your way up to a massive watermelon!
              </p>
              <p class="text-xs sm:text-sm leading-relaxed">
                Aim your dropper and click to drop. Realistic circle physics make the fruits roll and bounce! Make sure they don't pile up above the warning line, or it's game over!
              </p>
            </div>
            
            <div>
              <h3 class="text-lg font-black text-[#2c1e13] dark:text-ink mb-3 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-amber-500 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
                  <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
                  <path d="M4 22h16"></path>
                  <path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34"></path>
                  <path d="M12 2a5 5 0 0 0-5 5v3c0 2.2 1.8 4 4 4h2c2.2 0 4-1.8 4-4V7a5 5 0 0 0-5-5z"></path>
                </svg>
                Why Fruit Joy is the Best!
              </h3>
              <p class="mb-4 text-xs sm:text-sm leading-relaxed">
                We believe games should be clean and enjoyable. That's why Fruit Joy is a **fruit merge game with no ads**, meaning no annoying interruptions during your gameplay. 
              </p>
              <p class="text-xs sm:text-sm leading-relaxed">
                Whether you're playing on a computer, tablet, or phone, the game loads instantly and runs at a smooth 60 frames per second. It's also unblocked, so you can play cute matching games at school or on the go.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FAQ />

  <!-- Global Footer -->
  <Footer />
</Layout>
