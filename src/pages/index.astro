---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FruitGame from '../components/FruitGame.astro';
import { FRUITS } from '../components/game';
---

<Layout>
  <!-- Global navigation -->
  <Navbar />

  <!-- Hero Section with Atmospheric Mesh Gradient Backdrop -->
  <section class="relative w-full overflow-hidden bg-canvas transition-colors duration-200 py-20 lg:py-32">
    <!-- Mesh Gradients absolute positioned and heavily blurred -->
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none opacity-40 dark:opacity-20">
      <div class="absolute top-[-10%] left-[20%] w-[350px] h-[350px] rounded-full bg-develop-start filter blur-[100px] animate-pulse" style="animation-duration: 12s;"></div>
      <div class="absolute top-[10%] right-[20%] w-[400px] h-[400px] rounded-full bg-preview-start filter blur-[120px] animate-pulse" style="animation-duration: 8s; animation-delay: 2s;"></div>
      <div class="absolute bottom-[-10%] left-[35%] w-[380px] h-[380px] rounded-full bg-ship-start filter blur-[110px] animate-pulse" style="animation-duration: 15s; animation-delay: 4s;"></div>
    </div>

    <div class="relative z-10 max-w-[1400px] mx-auto px-4 md:px-6 flex flex-col items-center text-center">
      <!-- Eyebrow label -->
      <span class="inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-wider text-mute mb-6 px-3 py-1 bg-canvas-soft-2 border border-hairline rounded-full select-none">
        <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
        Super Fun Fruit Game
      </span>

      <!-- Sentence case period terminated headline -->
      <h1 class="font-sans font-semibold text-4xl sm:text-5xl md:text-6xl tracking-tight text-ink mb-6 max-w-4xl leading-[1.05]">
        Drop, Match, and Grow Huge Fruits!
      </h1>

      <!-- Body lead paragraph -->
      <p class="font-sans text-body text-base sm:text-lg md:text-xl max-w-2xl mb-8 leading-relaxed">
        Meet Fruit Gamer: a super fun game where you drop and combine fruits! Can you merge your way up to the giant watermelon?
      </p>

      <!-- CTA buttons -->
      <div class="flex items-center gap-3">
        <a 
          href="#game" 
          class="h-11 px-6 bg-ink text-canvas hover:bg-body font-medium text-sm rounded-full transition-colors duration-150 shadow-sm flex items-center"
        >
          Play Now
        </a>
        <a 
          href="#how-to-play" 
          class="h-11 px-6 bg-canvas text-ink hover:bg-canvas-soft-2 border border-hairline font-medium text-sm rounded-full transition-colors duration-150 shadow-sm flex items-center"
        >
          How to Play
        </a>
      </div>
    </div>
  </section>

  <!-- Interactive Game Area -->
  <section id="game" class="w-full bg-canvas-soft border-y border-hairline transition-colors duration-200 py-12">
    <FruitGame />
  </section>

  <!-- Progression System Path -->
  <section id="progression" class="w-full bg-canvas transition-colors duration-200 py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <span class="font-mono text-xs uppercase text-mute tracking-wider font-semibold">Fruit Evolution</span>
        <h2 class="font-sans font-semibold text-2xl md:text-3xl tracking-tight text-ink mt-2 mb-4">
          Watch your fruits grow!
        </h2>
        <p class="text-body text-sm max-w-lg mx-auto">
          Drop two of the same fruits together to combine them into a bigger, better fruit. Keep going to reach the top!
        </p>
      </div>

      <!-- Release path scrollable flex -->
      <div class="w-full overflow-x-auto pb-4 scrollbar-thin">
        <div class="min-w-[900px] flex items-center justify-between px-4">
          {FRUITS.map((fruit, idx) => (
            <div class="flex flex-col items-center gap-3 relative flex-1 group">
              <!-- Connection Line between items -->
              {idx < FRUITS.length - 1 && (
                <div class="absolute top-10 left-[50%] right-[-50%] h-[1px] bg-hairline group-hover:bg-hairline-strong transition-colors duration-200 z-0"></div>
              )}
              
              <!-- Badge -->
              <div 
                class="w-20 h-20 rounded-full flex flex-col items-center justify-center border border-hairline bg-canvas-soft-2 hover:bg-canvas shadow-sm transition-all duration-200 z-10 scale-100 group-hover:scale-110 relative"
                style={`box-shadow: 0 0 10px rgba(0,0,0,0.02);`}
              >
                <!-- Color glowing backplate -->
                <div 
                  class="absolute inset-0 rounded-full opacity-5 group-hover:opacity-15 transition-opacity" 
                  style={`background-color: ${fruit.color};`}
                ></div>
                <span class="text-3xl select-none">{fruit.emoji}</span>
              </div>
              
              <!-- Labels -->
              <div class="flex flex-col items-center text-center z-10">
                <span class="font-mono text-[11px] font-semibold text-ink">{fruit.name}</span>
                <span class="font-mono text-[10px] text-mute uppercase mt-0.5">Level {idx + 1}</span>
                <span class="text-[10px] px-1.5 py-0.5 rounded bg-canvas-soft-2 border border-hairline mt-1.5 text-mute font-mono">
                  +{fruit.score}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Environment / Modes Cards (3-up) -->
  <section id="modes" class="w-full bg-canvas-soft border-t border-hairline transition-colors duration-200 py-16 md:py-24">
    <div class="max-w-[1400px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <span class="font-mono text-xs uppercase text-mute tracking-wider font-semibold">Game Modes</span>
        <h2 class="font-sans font-semibold text-2xl md:text-3xl tracking-tight text-ink mt-2 mb-4">
          Ways to Play!
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1: Classic (Light canvas style) -->
        <div class="flex flex-col justify-between p-6 bg-canvas text-ink rounded-lg shadow-sm border border-hairline min-h-[220px] relative overflow-hidden group hover:shadow-md transition-shadow">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-[10px] uppercase tracking-wider text-mute font-semibold">Mode #01</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-canvas-soft-2 border border-hairline font-mono text-success">Normal</span>
            </div>
            <h3 class="font-sans font-semibold text-xl tracking-tight text-ink mb-2">Classic Game</h3>
            <p class="text-[13px] text-body leading-relaxed">
              Drop fruits carefully! Don't let the pile cross the red line at the top, or it's game over!
            </p>
          </div>
          <a href="#game" class="mt-6 text-xs font-mono text-link hover:underline flex items-center gap-1">
            Play Classic &rarr;
          </a>
        </div>

        <!-- Card 2: Zen (Light canvas style) -->
        <div class="flex flex-col justify-between p-6 bg-canvas text-ink rounded-lg shadow-sm border border-hairline min-h-[220px] relative overflow-hidden group hover:shadow-md transition-shadow">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-[10px] uppercase tracking-wider text-mute font-semibold">Mode #02</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-canvas-soft-2 border border-hairline font-mono text-body">Chill</span>
            </div>
            <h3 class="font-sans font-semibold text-xl tracking-tight text-ink mb-2">Zen Mode</h3>
            <p class="text-[13px] text-body leading-relaxed">
              Just relax and merge fruits. No losing, no stress! Keep playing as long as you want.
            </p>
          </div>
          <a href="#game" class="mt-6 text-xs font-mono text-link hover:underline flex items-center gap-1">
            Play Zen Mode &rarr;
          </a>
        </div>

        <!-- Card 3: Time Attack (Light canvas style) -->
        <div class="flex flex-col justify-between p-6 bg-canvas text-ink rounded-lg shadow-sm border border-hairline min-h-[220px] relative overflow-hidden group hover:shadow-md transition-shadow">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="font-mono text-[10px] uppercase tracking-wider text-mute font-semibold">Mode #03</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-canvas-soft-2 border border-hairline font-mono text-warning-deep">Fast</span>
            </div>
            <h3 class="font-sans font-semibold text-xl tracking-tight text-ink mb-2">Time Sprint</h3>
            <p class="text-[13px] text-body leading-relaxed">
              Go super fast! Get as many points and merges as you can in just 120 seconds.
            </p>
          </div>
          <a href="#game" class="mt-6 text-xs font-mono text-link hover:underline flex items-center gap-1">
            Start Sprint &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Play & Instructions (Readme format) -->
  <section id="how-to-play" class="w-full bg-canvas transition-colors duration-200 py-16 md:py-24">
    <div class="max-w-[800px] mx-auto px-4 md:px-6">
      
      <!-- Styled README structure -->
      <div class="border border-hairline rounded-lg overflow-hidden shadow-sm">
        <!-- Tab editor header -->
        <div class="bg-canvas-soft-2 border-b border-hairline px-4 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-hairline-strong flex items-center justify-center text-[8px] font-mono select-none">?</span>
            <span class="font-mono text-xs font-semibold text-body">Instructions</span>
          </div>
          <span class="font-mono text-[10px] text-mute">HOW TO PLAY</span>
        </div>
        
        <div class="p-6 md:p-8 bg-canvas text-ink select-text font-sans leading-relaxed text-sm md:text-base prose dark:prose-invert max-w-none">
          <h1 class="text-2xl font-bold tracking-tight text-ink mb-4 pb-2 border-b border-hairline flex items-center gap-2">
            <span>🎮</span> How to Play Fruit Gamer
          </h1>
          
          <p class="text-body mb-6">
            Fruit Gamer is a fun puzzle game where you drop fruits into a box. Combine the same fruits to make bigger ones and score points!
          </p>

          <h2 class="text-lg font-semibold tracking-tight text-ink mt-6 mb-3">🛠️ Game Rules</h2>
          
          <h3 class="text-sm font-semibold font-mono text-ink mt-4 mb-2">1. Drop Fruits</h3>
          <p class="text-body mb-4">
            Move your mouse or finger left and right to aim. <strong>Click or tap</strong> to drop the fruit into the box!
          </p>

          <h3 class="text-sm font-semibold font-mono text-ink mt-4 mb-2">2. Combine & Grow!</h3>
          <p class="text-body mb-4">
            When two of the same fruits touch (like Cherry + Cherry), they magically combine into a bigger fruit and give you points!
          </p>

          <h3 class="text-sm font-semibold font-mono text-ink mt-4 mb-2">3. Fun Power-Ups</h3>
          <p class="text-body mb-4">
            If you get stuck, use these cool power-up buttons:
          </p>
          <ul class="list-disc pl-5 mb-4 flex flex-col gap-1.5 text-body text-xs font-mono">
            <li><strong class="text-ink">Shake</strong>: Jiggles the box to mix up the fruits.</li>
            <li><strong class="text-ink">Clear Cherries</strong>: Removes all the tiny cherries to give you more room.</li>
            <li><strong class="text-ink">Magic Upgrade</strong>: Magically upgrades a fruit to the next size!</li>
          </ul>

          <h3 class="text-sm font-semibold font-mono text-ink mt-4 mb-2">4. Don't Overflow!</h3>
          <p class="text-body mb-4">
            Be careful! If your fruits pile up too high and cross the red line at the top, the game is over! Keep merging to make room.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Global Footer -->
  <Footer />
</Layout>
