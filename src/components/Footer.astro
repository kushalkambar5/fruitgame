---
// Footer component styled after Vercel's brand guidelines
---

<footer class="w-full bg-canvas border-t-3 border-[#2c1e13] transition-colors duration-200 mt-auto">
  <div class="max-w-[1200px] mx-auto py-12 px-4 md:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Col 1: Game -->
      <div class="flex flex-col gap-3">
        <h4 class="font-black text-xs uppercase tracking-wider text-amber-700 dark:text-amber-300 font-medium">Game Modes</h4>
        <ul class="flex flex-col gap-2 font-bold text-sm">
          <li><a href="#game" class="text-body hover:text-ink transition-colors duration-150">Classic Mode</a></li>
          <li><a href="#game" class="text-body hover:text-ink transition-colors duration-150">Zen Mode</a></li>
          <li><a href="#game" class="text-body hover:text-ink transition-colors duration-150">Time Sprint</a></li>
        </ul>
      </div>

      <!-- Col 2: Mechanics -->
      <div class="flex flex-col gap-3">
        <h4 class="font-black text-xs uppercase tracking-wider text-amber-700 dark:text-amber-300 font-medium">Game Rules</h4>
        <ul class="flex flex-col gap-2 font-bold text-sm">
          <li><a href="#progression" class="text-body hover:text-ink transition-colors duration-150">Fruit Grow Path</a></li>
          <li><a href="#how-to-play" class="text-body hover:text-ink transition-colors duration-150">Bouncing Physics</a></li>
          <li><a href="#how-to-play" class="text-body hover:text-ink transition-colors duration-150">Score & Combos</a></li>
        </ul>
      </div>

      <!-- Col 3: Platform -->
      <div class="flex flex-col gap-3">
        <h4 class="font-black text-xs uppercase tracking-wider text-amber-700 dark:text-amber-300 font-medium">Platform</h4>
        <ul class="flex flex-col gap-2 font-bold text-sm">
          <li><a href="/#game" class="text-body hover:text-ink transition-colors duration-150">Play Online</a></li>
          <li><a href="/about" class="text-body hover:text-ink transition-colors duration-150">About Us</a></li>
          <li><a href="/contact" class="text-body hover:text-ink transition-colors duration-150">Contact Us</a></li>
        </ul>
      </div>

      <!-- Col 4: Legal -->
      <div class="flex flex-col gap-3">
        <h4 class="font-black text-xs uppercase tracking-wider text-amber-700 dark:text-amber-300 font-medium">Legal</h4>
        <ul class="flex flex-col gap-2 font-bold text-sm">
          <li><a href="/privacy" class="text-body hover:text-ink transition-colors duration-150">Privacy Policy</a></li>
          <li><a href="/terms" class="text-body hover:text-ink transition-colors duration-150">Terms & Conditions</a></li>
          <li><span class="text-stone-400 dark:text-stone-500">For kids & fruit lovers</span></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="pt-8 border-t-2 border-[#2c1e13]/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
      </div>

      <div class="text-[12px] text-stone-400 font-black">
        &copy; {new Date().getFullYear()} Fruit Joy. Made with love for everyone!
      </div>
    </div>
  </div>
</footer>
