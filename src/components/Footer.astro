---
// Footer component styled after Vercel's brand guidelines
---

<footer class="w-full bg-canvas border-t border-hairline transition-colors duration-200 mt-auto">
  <div class="max-w-[1400px] mx-auto py-12 px-4 md:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Col 1: Game -->
      <div class="flex flex-col gap-3">
        <h4 class="font-mono text-xs uppercase tracking-wider text-mute font-medium">Game Modes</h4>
        <ul class="flex flex-col gap-2">
          <li><a href="#game" class="text-body hover:text-ink text-sm transition-colors duration-150">Classic Mode</a></li>
          <li><a href="#game" class="text-body hover:text-ink text-sm transition-colors duration-150">Zen Mode</a></li>
          <li><a href="#game" class="text-body hover:text-ink text-sm transition-colors duration-150">Time Attack</a></li>
        </ul>
      </div>

      <!-- Col 2: Mechanics -->
      <div class="flex flex-col gap-3">
        <h4 class="font-mono text-xs uppercase tracking-wider text-mute font-medium">Game Rules</h4>
        <ul class="flex flex-col gap-2">
          <li><a href="#progression" class="text-body hover:text-ink text-sm transition-colors duration-150">How Fruits Grow</a></li>
          <li><a href="#how-to-play" class="text-body hover:text-ink text-sm transition-colors duration-150">Bouncing Fruits</a></li>
          <li><a href="#how-to-play" class="text-body hover:text-ink text-sm transition-colors duration-150">Score Multiplier</a></li>
        </ul>
      </div>

      <!-- Col 3: Platform -->
      <div class="flex flex-col gap-3">
        <h4 class="font-mono text-xs uppercase tracking-wider text-mute font-medium">Platform</h4>
        <ul class="flex flex-col gap-2">
          <li><a href="/#game" class="text-body hover:text-ink text-sm transition-colors duration-150">Play Online</a></li>
          <li><a href="/about" class="text-body hover:text-ink text-sm transition-colors duration-150">About Us</a></li>
          <li><a href="/contact" class="text-body hover:text-ink text-sm transition-colors duration-150">Contact Us</a></li>
        </ul>
      </div>

      <!-- Col 4: Legal -->
      <div class="flex flex-col gap-3">
        <h4 class="font-mono text-xs uppercase tracking-wider text-mute font-medium">Legal</h4>
        <ul class="flex flex-col gap-2">
          <li><a href="/privacy" class="text-body hover:text-ink text-sm transition-colors duration-150">Privacy Policy</a></li>
          <li><a href="/terms" class="text-body hover:text-ink text-sm transition-colors duration-150">Terms & Conditions</a></li>
          <li><a href="https://vercel.com" target="_blank" rel="noopener noreferrer" class="text-body hover:text-ink text-sm transition-colors duration-150">Inspired by Vercel</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="pt-8 border-t border-hairline flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <!-- Status dot -->
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
        </span>
        <span class="font-mono text-[11px] text-mute">
          Ready to Play!
        </span>
      </div>

      <div class="text-[12px] text-mute font-sans">
        &copy; {new Date().getFullYear()} Fruit Gamer. Made with fun!
      </div>
    </div>
  </div>
</footer>
