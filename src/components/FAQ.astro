      <details class="group border border-hairline bg-canvas hover:border-hairline-strong transition-all duration-200 rounded-lg">
        <summary class="flex items-center justify-between p-5 cursor-pointer font-sans font-semibold text-sm md:text-base text-ink select-none list-none [&::-webkit-details-marker]:hidden">
