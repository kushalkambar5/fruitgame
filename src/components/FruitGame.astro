---
import { FRUITS } from './game';
---

<div class="w-full max-w-[800px] mx-auto px-4 py-6 flex flex-col items-center gap-6">
  
  <!-- Mode Selector: Cute Rounded Badges -->
  <div class="flex items-center bg-orange-100 dark:bg-canvas-soft-2 p-1.5 rounded-full border-3 border-[#2c1e13] shadow-md">
    <button 
      data-mode="classic" 
      class="game-mode-btn active px-4 py-1.5 rounded-full text-xs font-black transition-all duration-150 cursor-pointer text-[#2c1e13] flex items-center gap-1.5"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
        <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
        <path d="M4 22h16"></path>
        <path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34"></path>
        <path d="M12 2a5 5 0 0 0-5 5v3c0 2.2 1.8 4 4 4h2c2.2 0 4-1.8 4-4V7a5 5 0 0 0-5-5z"></path>
      </svg>
      Classic
    </button>
    <button 
      data-mode="zen" 
      class="game-mode-btn px-4 py-1.5 rounded-full text-xs font-black text-stone-500 dark:text-body hover:text-[#2c1e13] dark:hover:text-ink transition-all duration-150 cursor-pointer flex items-center gap-1.5"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2c1 2 2.5 3.5 4.5 4.5A12 12 0 0 1 22 12c-2 1-3.5 2.5-4.5 4.5A12 12 0 0 1 12 22c-1-2-2.5-3.5-4.5-4.5A12 12 0 0 1 2 12c2-1 3.5-2.5 4.5-4.5A12 12 0 0 1 12 2Z"></path>
      </svg>
      Zen Mode
    </button>
    <button 
      data-mode="time" 
      class="game-mode-btn px-4 py-1.5 rounded-full text-xs font-black text-stone-500 dark:text-body hover:text-[#2c1e13] dark:hover:text-ink transition-all duration-150 cursor-pointer flex items-center gap-1.5"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path>
      </svg>
      Time Sprint
    </button>
  </div>

  <!-- Playful Game Station Panel -->
  <div class="flex flex-col items-center w-full max-w-[466px]">
    
    <!-- Top Bar: Settings, Score Cloud, Next Preview -->
    <div class="flex items-center justify-between w-full px-2 mb-4 gap-3">
      <!-- Settings button (Yellow Cog) -->
      <button 
        id="settings-btn"
        class="w-12 h-12 rounded-2xl border-3 border-[#2c1e13] bg-[#fbbf24] hover:bg-[#f59e0b] shadow-md flex items-center justify-center cursor-pointer active:scale-95 transition-all duration-100"
        title="Settings"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#2c1e13] fill-none stroke-current" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
        </svg>
      </button>

      <!-- Fluffy Score Cloud -->
      <div class="relative bg-white dark:bg-canvas border-3 border-[#2c1e13] px-6 py-1 flex flex-col items-center justify-center shadow-lg rounded-3xl min-w-[140px] text-center z-10">
        <span class="text-[10px] font-black text-amber-600 dark:text-amber-400 flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
            <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
            <path d="M4 22h16"></path>
            <path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34"></path>
            <path d="M12 2a5 5 0 0 0-5 5v3c0 2.2 1.8 4 4 4h2c2.2 0 4-1.8 4-4V7a5 5 0 0 0-5-5z"></path>
          </svg> HIGH: <span id="metric-highscore">0</span>
        </span>
        <span id="metric-score" class="text-3xl font-black text-[#2c1e13] dark:text-ink leading-tight">0</span>
        <!-- Combo Pill -->
        <span id="metric-combo" class="absolute -bottom-2.5 bg-rose-500 text-white border-2 border-[#2c1e13] text-[9px] font-black px-2 py-0.5 rounded-full shadow-sm select-none">
          x0
        </span>
      </div>

      <!-- Next Preview Panel -->
      <div class="bg-white dark:bg-canvas border-3 border-[#2c1e13] rounded-2xl px-4 py-1.5 flex flex-col items-center justify-center shadow-lg min-w-[90px] min-h-[48px]">
        <span class="text-[9px] font-black text-stone-500 dark:text-body uppercase leading-none">Next</span>
        <div class="flex items-center gap-1 mt-0.5">
          <span id="metric-next-emoji" class="text-2xl select-none leading-none">🍒</span>
          <span id="metric-next-name" class="hidden text-[10px] font-bold text-stone-600">Cherry</span>
        </div>
      </div>
    </div>

    <!-- Timer Attack Display (Centred in this row if active) -->
    <div id="metric-timer-container" class="flex items-center justify-center bg-rose-100 border-2 border-rose-400 px-3 py-1.5 rounded-full text-rose-700 font-black text-xs mb-3 hidden">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1 text-rose-700 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      <span id="metric-timer">2:00</span>
    </div>

    <!-- Playground Container -->
    <div class="relative border-4 border-[#2c1e13] bg-[#fefefe] rounded-3xl p-1.5 shadow-2xl flex items-center justify-center overflow-hidden w-full">
      <!-- Game Canvas -->
      <canvas 
        id="game-canvas" 
        width="440" 
        height="640" 
        class="block rounded-2xl cursor-crosshair max-w-full"
      ></canvas>

      <!-- Start Overlay -->
      <div id="start-overlay" class="absolute inset-0 bg-[#dbeafe]/95 flex flex-col items-center justify-center p-6 text-center select-none z-10 transition-opacity duration-300">
        <div class="text-[#2c1e13] mb-4 animate-bounce">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-[#fbbf24] stroke-[#2c1e13] fill-[#fbbf24]" viewBox="0 0 24 24" stroke-width="2">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
        </div>
        <h2 class="font-black text-3xl tracking-tight text-[#3b2314] mb-2">Fruit Match Joy!</h2>
        <p class="text-stone-600 text-sm max-w-xs mb-6 font-medium">Drop cute fruits and combine matching ones to grow the giant Watermelon!</p>
        <button id="start-btn" class="h-12 px-8 bg-[#fbbf24] hover:bg-[#f59e0b] text-[#3b2314] border-3 border-[#2c1e13] font-black text-base rounded-full shadow-md active:scale-95 transition-all cursor-pointer">
          Let's Play!
        </button>
      </div>

      <!-- Game Over Overlay -->
      <div id="game-over-overlay" class="absolute inset-0 bg-stone-900/90 flex flex-col items-center justify-center p-6 text-center select-none z-10 hidden transition-opacity duration-300">
        <div class="text-rose-400 mb-4 animate-pulse">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="15" y1="9" x2="9" y2="15"></line>
            <line x1="9" y1="9" x2="15" y2="15"></line>
          </svg>
        </div>
        <h2 class="font-black text-3xl text-rose-400 mb-2">Oh No! Game Over!</h2>
        <p class="text-stone-300 text-sm max-w-xs mb-4" id="crash-reason">Your fruits crossed the warning line!</p>
        
        <div class="bg-stone-800 border-3 border-stone-700 p-4 rounded-2xl w-full max-w-xs mb-6 flex flex-col gap-0.5">
          <span class="text-xs text-stone-400 font-bold uppercase">Final Score</span>
          <span class="text-4xl font-black text-yellow-300" id="final-score">0</span>
          <span class="text-xs text-stone-400 font-bold flex items-center justify-center gap-1 mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-yellow-400 fill-yellow-400 stroke-none" viewBox="0 0 24 24">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg> Awesome job!
          </span>
        </div>

        <button id="restart-btn" class="h-12 px-8 bg-[#fbbf24] hover:bg-[#f59e0b] text-[#3b2314] border-3 border-[#2c1e13] font-black text-base rounded-full shadow-md active:scale-95 transition-all cursor-pointer">
          Play Again!
        </button>
      </div>
    </div>

    <!-- Cooldown / Help Prompt -->
    <div class="w-full mt-2 px-1 flex items-center justify-between text-[11px] text-[#6b432a] dark:text-body font-bold">
      <span>👆 Tap or Click container to Drop!</span>
      <span id="cooldown-indicator" class="text-green-600 hidden">● Ready!</span>
    </div>

    <!-- Wooden Log Evolution Path Bar at bottom -->
    <div class="w-full bg-[#b45309] border-3 border-[#2c1e13] rounded-2xl py-2 px-3 shadow-md mt-4 flex flex-col items-center">
      <span class="text-[9px] text-amber-100 font-black uppercase tracking-wider mb-1 flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="8" y1="6" x2="21" y2="6"></line>
          <line x1="8" y1="12" x2="21" y2="12"></line>
          <line x1="8" y1="18" x2="21" y2="18"></line>
          <line x1="3" y1="6" x2="3.01" y2="6"></line>
          <line x1="3" y1="12" x2="3.01" y2="12"></line>
          <line x1="3" y1="18" x2="3.01" y2="18"></line>
        </svg> Fruit Evolution Path
      </span>
      <div class="w-full flex items-center justify-between px-1 gap-1">
        {FRUITS.map((fruit, idx) => (
          <div class="flex flex-col items-center gap-0.5 relative group">
            <div class="w-8 h-8 rounded-full bg-[#fffbeb] border-2 border-[#2c1e13] flex items-center justify-center text-lg select-none shadow-sm transition-transform duration-100 hover:scale-110">
              {fruit.emoji}
            </div>
            <!-- Display coins/badges under Melon & Watermelon -->
            {idx === 8 && <span class="text-[8px] font-bold text-amber-200 leading-none">10🪙</span>}
            {idx === 9 && <span class="text-[8px] font-bold text-amber-200 leading-none">30🪙</span>}
          </div>
        ))}
      </div>
    </div>

  </div>
</div>

<!-- Settings Drawer / Modal -->
<div id="settings-modal" class="fixed inset-0 bg-stone-950/70 z-50 flex items-center justify-center hidden select-none">
  <div class="bg-white dark:bg-canvas border-4 border-[#2c1e13] rounded-3xl p-6 w-80 max-w-full shadow-2xl relative">
    <button id="close-settings" class="absolute top-2 right-2 w-8 h-8 rounded-full border-2 border-[#2c1e13] bg-rose-100 text-[#2c1e13] hover:bg-rose-200 font-black cursor-pointer flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 stroke-current" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <h3 class="text-xl font-black text-[#2c1e13] dark:text-ink mb-4 text-center flex items-center justify-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"></circle>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
      </svg>
      Settings
    </h3>
    
    <div class="flex flex-col gap-3">
      <!-- Quick Reset -->
      <div class="flex items-center justify-between border-b border-stone-100 dark:border-hairline pb-2">
        <span class="text-sm font-black text-[#6b432a] dark:text-body flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 stroke-current fill-none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path>
          </svg>
          Reset High Scores
        </span>
        <button id="reset-scores" class="px-2.5 py-1 text-xs font-black bg-rose-100 text-rose-700 border-2 border-[#2c1e13] rounded-lg cursor-pointer hover:bg-rose-200">Reset</button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Custom button state classes for active mode */
  .game-mode-btn.active {
    background-color: #fbbf24;
    color: #2c1e13;
    border: 2px solid #2c1e13;
    box-shadow: 0 2px 0px #2c1e13;
  }
</style>

<script>
  import { GameEngine, FRUITS, type LogType, type GameStats } from './game';

  let game: GameEngine | null = null;
  let activeMode: 'classic' | 'zen' | 'time' = (localStorage.getItem('fg_active_mode') as any) || 'classic';

  // DOM elements
  const canvas = document.getElementById('game-canvas') as HTMLCanvasElement;
  const startOverlay = document.getElementById('start-overlay') as HTMLDivElement;
  const gameOverOverlay = document.getElementById('game-over-overlay') as HTMLDivElement;
  const crashReasonText = document.getElementById('crash-reason') as HTMLParagraphElement;
  const startBtn = document.getElementById('start-btn') as HTMLButtonElement;
  const restartBtn = document.getElementById('restart-btn') as HTMLButtonElement;
  
  // Settings Modal Elements
  const settingsBtn = document.getElementById('settings-btn') as HTMLButtonElement;
  const settingsModal = document.getElementById('settings-modal') as HTMLDivElement;
  const closeSettings = document.getElementById('close-settings') as HTMLButtonElement;
  const resetScoresBtn = document.getElementById('reset-scores') as HTMLButtonElement;

  // Dashboard Metrics
  const metricScore = document.getElementById('metric-score') as HTMLSpanElement;
  const metricHighScore = document.getElementById('metric-highscore') as HTMLSpanElement;
  const metricCombo = document.getElementById('metric-combo') as HTMLSpanElement;
  const metricNextEmoji = document.getElementById('metric-next-emoji') as HTMLSpanElement;
  const metricNextName = document.getElementById('metric-next-name') as HTMLSpanElement;
  const finalScoreText = document.getElementById('final-score') as HTMLSpanElement;
  const metricTimerContainer = document.getElementById('metric-timer-container') as HTMLDivElement;
  const metricTimer = document.getElementById('metric-timer') as HTMLSpanElement;

  // Mode Buttons
  const modeButtons = document.querySelectorAll('.game-mode-btn');

  // Set up terminal logging
  function addLog(message: string, type: LogType) {
    // Console log to see activity
    console.log(`[FruitGame] ${message}`);
  }

  // Load Highscore helper for visual preview
  function updateHighScoreUI(mode: 'classic' | 'zen' | 'time') {
    const savedHighScore = localStorage.getItem(`fg_highscore_${mode}`) || '0';
    metricHighScore.textContent = savedHighScore;
  }

  // Initialize high score UI on first load
  updateHighScoreUI(activeMode);

  // Sync mode button styling on load
  modeButtons.forEach((btn) => {
    const mode = btn.getAttribute('data-mode') as 'classic' | 'zen' | 'time';
    if (mode === activeMode) {
      btn.classList.add('active');
      btn.classList.remove('text-stone-500', 'dark:text-body');
    } else {
      btn.classList.remove('active');
      btn.classList.add('text-stone-500', 'dark:text-body');
    }
  });

  // Update metrics UI
  function updateStatsUI(stats: GameStats) {
    metricScore.textContent = stats.score.toString();
    metricHighScore.textContent = stats.highScore.toString();
    metricCombo.textContent = stats.combo > 0 ? `x${stats.combo}` : 'x0';

    // Trigger visual highlights for combo
    if (stats.combo > 1) {
      metricCombo.classList.add('scale-110', 'bg-rose-600');
      setTimeout(() => metricCombo.classList.remove('scale-110', 'bg-rose-600'), 200);
    }

    // Update Next Asset preview
    if (game) {
      const nextIndex = (game as any).nextFruitIndex;
      const nextFruit = FRUITS[nextIndex];
      metricNextEmoji.textContent = nextFruit.emoji;
      metricNextName.textContent = nextFruit.name;
    }
  }

  // Handle Game Timer for Time Attack
  function updateTimerUI(seconds: number) {
    if (activeMode !== 'time') {
      metricTimerContainer.classList.add('hidden');
      return;
    }
    metricTimerContainer.classList.remove('hidden');
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    metricTimer.textContent = `${mins}:${secs < 10 ? '0' : ''}${secs}`;
  }

  // Initialize Game Instance
  function initGame() {
    if (game) {
      game.destroy();
    }

    if (activeMode === 'time') {
      metricTimerContainer.classList.remove('hidden');
      metricTimer.textContent = '2:00';
    } else {
      metricTimerContainer.classList.add('hidden');
    }

    game = new GameEngine(canvas, {
      onLog: (msg, type) => addLog(msg, type),
      onStats: (stats) => updateStatsUI(stats),
      onTimer: (seconds) => updateTimerUI(seconds),
      onGameOver: (score, reason) => {
        gameOverOverlay.classList.remove('hidden');
        finalScoreText.textContent = score.toString();
        
        if (reason) {
          crashReasonText.textContent = `Reason: ${reason}`;
        } else if (activeMode === 'time') {
          crashReasonText.textContent = 'Reason: Time ran out! (120s limit).';
        } else {
          crashReasonText.textContent = 'Reason: Fruits crossed the warning line for too long!';
        }
      }
    });

    // Start running the engine
    game.start(activeMode);

    // Initial Stats Load
    updateStatsUI(game.stats);
  }

  // Settings Drawer Toggle
  settingsBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    settingsModal.classList.remove('hidden');
  });

  closeSettings.addEventListener('click', () => {
    settingsModal.classList.add('hidden');
  });

  settingsModal.addEventListener('click', (e) => {
    if (e.target === settingsModal) {
      settingsModal.classList.add('hidden');
    }
  });

  // Reset High Scores
  resetScoresBtn.addEventListener('click', () => {
    if (window.confirm("Are you sure you want to reset all high scores?")) {
      localStorage.removeItem('fg_highscore_classic');
      localStorage.removeItem('fg_highscore_zen');
      localStorage.removeItem('fg_highscore_time');
      updateHighScoreUI(activeMode);
      if (game) {
        game.stats.highScore = 0;
        updateStatsUI(game.stats);
      }
      alert("High scores reset successfully!");
    }
  });

  // Bind Start Buttons
  startBtn.addEventListener('click', () => {
    startOverlay.classList.add('hidden');
    initGame();
  });

  restartBtn.addEventListener('click', () => {
    gameOverOverlay.classList.add('hidden');
    initGame();
  });

  // Mode Selection Links
  modeButtons.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const mode = target.getAttribute('data-mode') as 'classic' | 'zen' | 'time';

      if (mode === activeMode) return;

      // Check if a game is actively in progress
      const isGameActive = game && !game.gameOver && startOverlay.classList.contains('hidden');
      if (isGameActive) {
        const confirmChange = window.confirm(`Switch to ${target.textContent?.trim()}? Your current game progress will be lost.`);
        if (!confirmChange) {
          return; // Cancelled
        }
      }

      modeButtons.forEach((b) => {
        b.classList.remove('active');
        b.classList.add('text-stone-500', 'dark:text-body');
      });
      
      target.classList.add('active');
      target.classList.remove('text-stone-500', 'dark:text-body');

      activeMode = mode;
      localStorage.setItem('fg_active_mode', mode);
      updateHighScoreUI(mode);

      // Automatically restart with new environment if game has started or is over
      if (!startOverlay.classList.contains('hidden')) {
        // Just prepare start screen with new mode config
      } else {
        gameOverOverlay.classList.add('hidden');
        initGame();
      }
    });
  });

  // Dropper Mechanics: mouse/touch events inside canvas with responsiveness scaling
  canvas.addEventListener('mousemove', (e) => {
    if (!game) return;
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (canvas.width / rect.width);
    game.updatePreviewX(x);
  });

  canvas.addEventListener('touchmove', (e) => {
    if (!game) return;
    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];
    const x = (touch.clientX - rect.left) * (canvas.width / rect.width);
    game.updatePreviewX(x);
  }, { passive: true });

  canvas.addEventListener('mousedown', (e) => {
    if (!game) return;
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (canvas.width / rect.width);
    const y = (e.clientY - rect.top) * (canvas.height / rect.height);

    if (game.hotfixActive) {
      game.applyHotfixClick(x, y);
    } else {
      game.dropActiveFruit(x);
    }
    
    // Pull statistics post action
    updateStatsUI(game.stats);
  });

  canvas.addEventListener('touchend', (e) => {
    if (!game) return;
    const rect = canvas.getBoundingClientRect();
    const touch = e.changedTouches[0];
    const x = (touch.clientX - rect.left) * (canvas.width / rect.width);
    const y = (touch.clientY - rect.top) * (canvas.height / rect.height);

    if (game.hotfixActive) {
      game.applyHotfixClick(x, y);
    } else {
      game.dropActiveFruit(x);
    }

    updateStatsUI(game.stats);
  });
</script>
