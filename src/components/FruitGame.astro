---
import { FRUITS } from './game';
---

<div class="w-full max-w-[1400px] mx-auto px-4 md:px-6 py-8 flex flex-col gap-8">
  
  <!-- Top Bar: Game Mode Selector -->
  <div class="flex flex-col sm:flex-row items-center justify-between border border-hairline bg-canvas p-4 rounded-lg gap-4 shadow-sm">
    <div class="flex items-center gap-3">
      <span class="w-2.5 h-2.5 rounded-full bg-success"></span>
      <h3 class="font-sans font-semibold text-sm tracking-[-0.28px] text-ink">Game Mode</h3>
    </div>
    
    <!-- Mode Tab Row (Ghost Pills) -->
    <div class="flex items-center bg-canvas-soft-2 p-1 rounded-full border border-hairline">
      <button 
        data-mode="classic" 
        class="game-mode-btn active px-4 py-1.5 rounded-full text-xs font-medium transition-all duration-150 cursor-pointer"
      >
        Classic (Normal)
      </button>
      <button 
        data-mode="zen" 
        class="game-mode-btn px-4 py-1.5 rounded-full text-xs font-medium text-body hover:text-ink transition-all duration-150 cursor-pointer"
      >
        Zen (Chill)
      </button>
      <button 
        data-mode="time" 
        class="game-mode-btn px-4 py-1.5 rounded-full text-xs font-medium text-body hover:text-ink transition-all duration-150 cursor-pointer"
      >
        Time Attack (Fast)
      </button>
    </div>
  </div>

  <!-- Three-Column Layout: Evolution Path + Centered Playground + Vertical Stats -->
  <div class="flex flex-col lg:flex-row items-center lg:items-start justify-center gap-8 w-full">
    
    <!-- Column A (lg:w-[220px]): Evolution Path Legend -->
    <div class="hidden lg:flex flex-col gap-3 w-[220px] border border-hairline bg-canvas p-4 rounded-xl shadow-sm">
      <span class="font-mono text-[10px] uppercase text-mute tracking-wider font-semibold mb-2">Evolution Path</span>
      <div class="flex flex-col gap-2">
        {FRUITS.map((fruit, idx) => (
          <div class="flex items-center justify-between border-b border-hairline/50 pb-1.5 last:border-0 last:pb-0">
            <div class="flex items-center gap-2">
              <span class="text-xl select-none">{fruit.emoji}</span>
              <span class="text-xs font-sans font-medium text-ink">{fruit.name}</span>
            </div>
            <span class="text-[9px] font-mono text-mute bg-canvas-soft-2 px-1.5 py-0.5 rounded border border-hairline">+{fruit.score}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Column B: Game Board Container (Playground in the middle) -->
    <div class="flex flex-col items-center justify-center w-full max-w-[466px]">
      <div class="relative border border-hairline bg-canvas rounded-xl p-3 shadow-md flex items-center justify-center overflow-hidden w-full">
        
        <!-- Game Canvas -->
        <canvas 
          id="game-canvas" 
          width="440" 
          height="640" 
          class="block rounded-lg cursor-crosshair max-w-full"
        ></canvas>

        <!-- Start Overlay -->
        <div id="start-overlay" class="absolute inset-0 bg-canvas/90 flex flex-col items-center justify-center p-6 text-center select-none z-10 transition-opacity duration-300">
          <div class="w-12 h-12 flex items-center justify-center rounded-full bg-canvas border border-hairline shadow-sm text-lg mb-4 text-develop-start">
            <!-- Premium Game Controller SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="6" y1="12" x2="10" y2="12"></line>
              <line x1="8" y1="10" x2="8" y2="14"></line>
              <line x1="15" y1="13" x2="15.01" y2="13"></line>
              <line x1="18" y1="11" x2="18.01" y2="11"></line>
              <rect x="2" y="6" width="20" height="12" rx="3"></rect>
            </svg>
          </div>
          <h2 class="font-sans font-semibold text-2xl tracking-[-0.96px] text-ink mb-2">Ready to Play?</h2>
          <p class="text-body text-sm max-w-xs mb-6">Drop fruits into the box and merge them to make the biggest fruit!</p>
          <button id="start-btn" class="h-10 px-6 bg-ink text-canvas hover:bg-body font-medium text-sm rounded-full transition-colors duration-150 cursor-pointer">
            Start Game
          </button>
        </div>

        <!-- Game Over Overlay -->
        <div id="game-over-overlay" class="absolute inset-0 bg-canvas/95 flex flex-col items-center justify-center p-6 text-center select-none z-10 hidden transition-opacity duration-300">
          <div class="w-12 h-12 flex items-center justify-center rounded-full bg-error/10 text-error mb-4 animate-bounce">
            <!-- Premium Siren Alert SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </div>
          <h2 class="font-sans font-semibold text-2xl tracking-[-0.96px] text-error mb-2">Game Over!</h2>
          <p class="text-body text-sm max-w-xs mb-1">Your fruits piled up too high.</p>
          <p class="font-mono text-xs text-mute mb-6" id="crash-reason">Reason: Out of memory.</p>
          
          <div class="bg-canvas-soft border border-hairline p-4 rounded-md w-full max-w-xs mb-6 flex flex-col gap-1">
            <span class="text-xs text-mute font-mono">FINAL METRICS</span>
            <span class="text-3xl font-semibold tracking-[-1.28px] text-ink" id="final-score">0</span>
            <span class="text-xs text-mute font-mono">points scored</span>
          </div>

          <button id="restart-btn" class="h-10 px-6 bg-ink text-canvas hover:bg-body font-medium text-sm rounded-full transition-colors duration-150 cursor-pointer">
            Play Again
          </button>
        </div>
      </div>

      <!-- Cooldown Loader/Prompt under Canvas -->
      <div class="w-full mt-2 px-1 flex items-center justify-between text-xs text-mute font-mono">
        <span>DROP: MOUSE OVER CONTAINER + CLICK</span>
        <span id="cooldown-indicator" class="text-success hidden">● READY TO DROP</span>
      </div>
    </div>

    <!-- Column C: Control Panel Dashboard (Grid on mobile/tablet, vertical stack on desktop) -->
    <div class="grid grid-cols-2 sm:grid-cols-5 lg:grid-cols-1 lg:flex lg:flex-col gap-3 w-full max-w-[466px] lg:w-[220px]">
      <!-- Panel 1: Score -->
      <div class="border border-hairline bg-canvas p-3 sm:p-4 rounded-lg shadow-sm flex flex-col justify-between h-[80px] sm:h-[96px]">
        <span class="font-mono text-[10px] uppercase text-mute tracking-wider font-semibold">Score</span>
        <span id="metric-score" class="text-2xl sm:text-3xl font-semibold tracking-[-1.28px] text-ink font-mono">0</span>
      </div>
      
      <!-- Panel 2: High Score -->
      <div class="border border-hairline bg-canvas p-3 sm:p-4 rounded-lg shadow-sm flex flex-col justify-between h-[80px] sm:h-[96px]">
        <span class="font-mono text-[10px] uppercase text-mute tracking-wider font-semibold">High Score</span>
        <span id="metric-highscore" class="text-2xl sm:text-3xl font-semibold tracking-[-1.28px] text-ink font-mono">0</span>
      </div>

      <!-- Panel 3: Combo -->
      <div class="border border-hairline bg-canvas p-3 sm:p-4 rounded-lg shadow-sm flex flex-col justify-between h-[80px] sm:h-[96px]">
        <span class="font-mono text-[10px] uppercase text-mute tracking-wider font-semibold">Combo</span>
        <span id="metric-combo" class="text-2xl sm:text-3xl font-semibold tracking-[-1.28px] text-ink font-mono">x0</span>
      </div>

      <!-- Panel 4: Next Asset -->
      <div class="border border-hairline bg-canvas p-3 sm:p-4 rounded-lg shadow-sm flex flex-col justify-between h-[80px] sm:h-[96px]">
        <span class="font-mono text-[10px] uppercase text-mute tracking-wider font-semibold">Next Fruit</span>
        <div class="flex items-center justify-between mt-1 sm:mt-0">
          <span id="metric-next-emoji" class="text-2xl sm:text-3xl select-none">🍒</span>
          <span id="metric-next-name" class="font-sans font-medium text-[10px] sm:text-xs text-body">Cherry</span>
        </div>
      </div>

      <!-- Panel 5: Timer (Visible only in Time Attack mode) -->
      <div id="metric-timer-container" class="border border-hairline bg-canvas p-3 sm:p-4 rounded-lg shadow-sm flex flex-col justify-between h-[80px] sm:h-[96px] hidden transition-all col-span-2 sm:col-span-1 lg:col-span-1">
        <span class="font-mono text-[10px] uppercase text-mute tracking-wider font-semibold">Time Remaining</span>
        <span id="metric-timer" class="text-2xl sm:text-3xl font-semibold tracking-[-1.28px] text-ink font-mono">2:00</span>
      </div>
    </div>
  </div>
</div>

<style>
  /* Custom button state classes for active mode */
  .game-mode-btn.active {
    background-color: var(--canvas);
    color: var(--ink);
    border-color: var(--hairline-strong);
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  }
</style>

<script>
  import { GameEngine, FRUITS, type LogType, type GameStats } from './game';

  let game: GameEngine | null = null;
  let activeMode: 'classic' | 'zen' | 'time' = (localStorage.getItem('fg_active_mode') as any) || 'classic';

  // DOM elements
  const canvas = document.getElementById('game-canvas') as HTMLCanvasElement;
  const startOverlay = document.getElementById('start-overlay') as HTMLDivElement;
  const gameOverOverlay = document.getElementById('game-over-overlay') as HTMLDivElement;
  const crashReasonText = document.getElementById('crash-reason') as HTMLParagraphElement;
  const startBtn = document.getElementById('start-btn') as HTMLButtonElement;
  const restartBtn = document.getElementById('restart-btn') as HTMLButtonElement;
  
  // Dashboard Metrics
  const metricScore = document.getElementById('metric-score') as HTMLSpanElement;
  const metricHighScore = document.getElementById('metric-highscore') as HTMLSpanElement;
  const metricCombo = document.getElementById('metric-combo') as HTMLSpanElement;
  const metricNextEmoji = document.getElementById('metric-next-emoji') as HTMLSpanElement;
  const metricNextName = document.getElementById('metric-next-name') as HTMLSpanElement;
  const finalScoreText = document.getElementById('final-score') as HTMLSpanElement;
  const metricTimerContainer = document.getElementById('metric-timer-container') as HTMLDivElement;
  const metricTimer = document.getElementById('metric-timer') as HTMLSpanElement;

  // Mode Buttons
  const modeButtons = document.querySelectorAll('.game-mode-btn');

  // Set up terminal logging
  function addLog(message: string, type: LogType) {
    // Terminal removed
  }

  // Load Highscore helper for visual preview
  function updateHighScoreUI(mode: 'classic' | 'zen' | 'time') {
    const savedHighScore = localStorage.getItem(`fg_highscore_${mode}`) || '0';
    metricHighScore.textContent = savedHighScore;
  }

  // Initialize high score UI on first load
  updateHighScoreUI(activeMode);

  // Sync mode button styling on load
  modeButtons.forEach((btn) => {
    const mode = btn.getAttribute('data-mode') as 'classic' | 'zen' | 'time';
    if (mode === activeMode) {
      btn.classList.add('active', 'text-ink');
      btn.classList.remove('text-body');
    } else {
      btn.classList.remove('active', 'text-ink');
      btn.classList.add('text-body');
    }
  });

  // Update metrics UI
  function updateStatsUI(stats: GameStats) {
    metricScore.textContent = stats.score.toString();
    metricHighScore.textContent = stats.highScore.toString();
    metricCombo.textContent = stats.combo > 0 ? `x${stats.combo}` : 'x0';

    // Trigger visual highlights
    if (stats.combo > 1) {
      metricCombo.classList.add('text-success', 'scale-105');
      setTimeout(() => metricCombo.classList.remove('text-success', 'scale-105'), 200);
    }

    // Update Next Asset preview
    if (game) {
      const nextIndex = (game as any).nextFruitIndex;
      const nextFruit = FRUITS[nextIndex];
      metricNextEmoji.textContent = nextFruit.emoji;
      metricNextName.textContent = nextFruit.name;
    }
  }

  // Handle Game Timer for Time Attack
  function updateTimerUI(seconds: number) {
    if (activeMode !== 'time') {
      metricTimerContainer.classList.add('hidden');
      return;
    }
    metricTimerContainer.classList.remove('hidden');
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    metricTimer.textContent = `${mins}:${secs < 10 ? '0' : ''}${secs}`;
  }

  // Initialize Game Instance
  function initGame() {
    if (game) {
      game.destroy();
    }

    if (activeMode === 'time') {
      metricTimerContainer.classList.remove('hidden');
      metricTimer.textContent = '2:00';
    } else {
      metricTimerContainer.classList.add('hidden');
    }

    game = new GameEngine(canvas, {
      onLog: (msg, type) => addLog(msg, type),
      onStats: (stats) => updateStatsUI(stats),
      onTimer: (seconds) => updateTimerUI(seconds),
      onGameOver: (score) => {
        gameOverOverlay.classList.remove('hidden');
        finalScoreText.textContent = score.toString();
        
        if (activeMode === 'time') {
          crashReasonText.textContent = 'Reason: Time ran out! (120s limit).';
        } else {
          crashReasonText.textContent = 'Reason: Fruits crossed the red line for too long!';
        }
      }
    });

    // Start running the engine
    game.start(activeMode);

    // Initial Stats Load
    updateStatsUI(game.stats);
  }

  // Bind Start Buttons
  startBtn.addEventListener('click', () => {
    startOverlay.classList.add('hidden');
    initGame();
  });

  restartBtn.addEventListener('click', () => {
    gameOverOverlay.classList.add('hidden');
    initGame();
  });

  // Mode Selection Links
  modeButtons.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const mode = target.getAttribute('data-mode') as 'classic' | 'zen' | 'time';

      if (mode === activeMode) return;

      // Check if a game is actively in progress
      const isGameActive = game && !game.gameOver && !startOverlay.classList.contains('hidden');
      if (isGameActive) {
        const confirmChange = window.confirm(`Switch to ${target.textContent?.trim()}? Your current game progress will be lost.`);
        if (!confirmChange) {
          return; // Cancelled
        }
      }

      modeButtons.forEach((b) => b.classList.remove('active', 'text-ink'));
      modeButtons.forEach((b) => b.classList.add('text-body'));
      
      target.classList.add('active', 'text-ink');
      target.classList.remove('text-body');

      activeMode = mode;
      localStorage.setItem('fg_active_mode', mode);
      updateHighScoreUI(mode);

      // Automatically restart with new environment if game has started or is over
      if (!startOverlay.classList.contains('hidden')) {
        // Just prepare start screen with new mode config
      } else {
        gameOverOverlay.classList.add('hidden');
        initGame();
      }
    });
  });

  // Dropper Mechanics: mouse/touch events inside canvas with responsiveness scaling
  canvas.addEventListener('mousemove', (e) => {
    if (!game) return;
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (canvas.width / rect.width);
    game.updatePreviewX(x);
  });

  canvas.addEventListener('touchmove', (e) => {
    if (!game) return;
    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];
    const x = (touch.clientX - rect.left) * (canvas.width / rect.width);
    game.updatePreviewX(x);
  }, { passive: true });

  canvas.addEventListener('mousedown', (e) => {
    if (!game) return;
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (canvas.width / rect.width);
    const y = (e.clientY - rect.top) * (canvas.height / rect.height);

    if (game.hotfixActive) {
      game.applyHotfixClick(x, y);
    } else {
      game.dropActiveFruit(x);
    }
    
    // Pull statistics post action
    updateStatsUI(game.stats);
  });

  canvas.addEventListener('touchend', (e) => {
    if (!game) return;
    const rect = canvas.getBoundingClientRect();
    const touch = e.changedTouches[0];
    const x = (touch.clientX - rect.left) * (canvas.width / rect.width);
    const y = (touch.clientY - rect.top) * (canvas.height / rect.height);

    if (game.hotfixActive) {
      game.applyHotfixClick(x, y);
    } else {
      game.dropActiveFruit(x);
    }

    updateStatsUI(game.stats);
  });
</script>
